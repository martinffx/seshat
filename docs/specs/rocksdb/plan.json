{
  "spec": "docs/specs/rocksdb/spec.md",
  "feature": "rocksdb-storage",
  "description": "Persistent storage layer with RocksDB for durability",
  "status": "not_started",
  "estimated_effort_hours": "14-17",
  "dependencies": ["seshat-1h4"],

  "phases": [
    {
      "id": "T1",
      "name": "Initialization",
      "description": "Set up RocksDB with 6 column families and optimized configuration",
      "tasks": ["T1.1", "T1.2", "T1.3"]
    },
    {
      "id": "T2",
      "name": "CRUD Operations",
      "description": "Implement basic get/put/delete/exists and batch write operations",
      "depends_on": ["T1"],
      "tasks": ["T2.1", "T2.2", "T2.3", "T2.4", "T2.5"]
    },
    {
      "id": "T3",
      "name": "Raft Log Storage",
      "description": "Implement RaftLogStorage trait for log persistence",
      "depends_on": ["T2"],
      "tasks": ["T3.1", "T3.2", "T3.3", "T3.4"]
    },
    {
      "id": "T4",
      "name": "State Machine Storage",
      "description": "Implement RaftStateMachine trait for KV persistence",
      "depends_on": ["T3"],
      "tasks": ["T4.1", "T4.2", "T4.3", "T4.4"]
    },
    {
      "id": "T5",
      "name": "OpenRaft Integration",
      "description": "Integrate RocksDB storage with OpenRaft storage traits and test",
      "depends_on": ["T4"],
      "tasks": ["T5.1", "T5.2", "T5.3"]
    }
  ],

  "tasks": {
    "T1.1": {
      "name": "Create column families",
      "description": "Initialize RocksDB with 6 column families: system_raft_log, system_raft_state, system_data, data_raft_log, data_raft_state, data_kv",
      "acceptance": [
        "Column family 'system_raft_log' created",
        "Column family 'system_raft_state' created",
        "Column family 'system_data' created",
        "Column family 'data_raft_log' created",
        "Column family 'data_raft_state' created",
        "Column family 'data_kv' created"
      ],
      "files": ["crates/storage/src/column_family.rs", "crates/storage/src/lib.rs"],
      "depends_on": []
    },
    "T1.2": {
      "name": "Configure RocksDB options",
      "description": "Set optimized RocksDB options: LZ4 compression, bloom filters for data_kv, 64MB write buffers, WAL enabled",
      "acceptance": [
        "LZ4 compression enabled",
        "Bloom filter for data_kv",
        "64MB block cache",
        "WAL enabled for durability"
      ],
      "files": ["crates/storage/src/options.rs"],
      "depends_on": ["T1.1"]
    },
    "T1.3": {
      "name": "Test open/close lifecycle",
      "description": "Test RocksDB can be opened and closed cleanly, verify data persists across reopen",
      "acceptance": [
        "Open succeeds with valid path",
        "Close succeeds without error",
        "Reopen preserves data"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": ["T1.2"]
    },

    "T2.1": {
      "name": "Implement get operation",
      "description": "Implement get(cf, key) -> Option<Vec<u8>>",
      "acceptance": [
        "Returns Some(value) if key exists",
        "Returns None if key doesn't exist",
        "Works on all column families"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": []
    },
    "T2.2": {
      "name": "Implement put operation",
      "description": "Implement put(cf, key, value) with fsync for raft_state CFs",
      "acceptance": [
        "Stores value at key",
        "Value is immediately readable",
        "Value persists across reopen",
        "Fsync called for raft_state CFs"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": ["T2.1"]
    },
    "T2.3": {
      "name": "Implement delete operation",
      "description": "Implement delete(cf, key)",
      "acceptance": [
        "Removes key from CF",
        "exists() returns false after delete",
        "No error on non-existent key"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": ["T2.2"]
    },
    "T2.4": {
      "name": "Implement exists operation",
      "description": "Implement exists(cf, key) -> bool using bloom filter optimization",
      "acceptance": [
        "Returns true if key exists",
        "Returns false if key doesn't exist"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": ["T2.3"]
    },
    "T2.5": {
      "name": "Implement batch writes",
      "description": "Implement WriteBatch builder for atomic batch writes across multiple CFs",
      "acceptance": [
        "WriteBatch writes multiple keys atomically",
        "commit() is all-or-nothing",
        "fsync called when raft_state CF touched"
      ],
      "files": ["crates/storage/src/batch.rs", "crates/storage/src/lib.rs"],
      "depends_on": ["T2.4"]
    },

    "T3.1": {
      "name": "Implement log append",
      "description": "Implement append operation for Raft log entries with sequential index validation",
      "acceptance": [
        "Appends entry to data_raft_log CF",
        "Key format: log:{index}",
        "Validates no gaps in log indices",
        "First entry must have index 1"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": []
    },
    "T3.2": {
      "name": "Implement log range query",
      "description": "Implement get_log_entries(low, high) for range scans",
      "acceptance": [
        "Returns entries in range [low, high)",
        "Entries in correct order",
        "Handles compacted gaps (empty entries skipped)"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": ["T3.1"]
    },
    "T3.3": {
      "name": "Implement log truncate",
      "description": "Implement truncate_log_after(index) for log compaction",
      "acceptance": [
        "Removes entries with index > given",
        "Preserves entries <= given index",
        "Atomic batch delete"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": ["T3.2"]
    },
    "T3.4": {
      "name": "Implement vote storage",
      "description": "Implement persistent vote storage in data_raft_state with fsync",
      "acceptance": [
        "Vote persisted to data_raft_state",
        "Fsync before returning",
        "Vote survives restart"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": ["T3.3"]
    },

    "T4.1": {
      "name": "Implement state get",
      "description": "Implement state machine get operation for data_kv",
      "acceptance": [
        "Gets value from data_kv CF",
        "Returns raw bytes"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": []
    },
    "T4.2": {
      "name": "Implement state put",
      "description": "Implement state machine put operation for data_kv",
      "acceptance": [
        "Stores key-value in data_kv CF",
        "Key is user's key (from Operation)",
        "Value is user's value"
      ],
      "files": ["crates/storage/src/lib.rs"],
      "depends_on": ["T4.1"]
    },
    "T4.3": {
      "name": "Implement snapshot creation",
      "description": "Implement snapshot creation via RocksDB checkpoint (hard links)",
      "acceptance": [
        "Creates checkpoint directory",
        "Checkpoint contains all data_kv data",
        "Records last_included_index in metadata",
        "O(1) time using hard links"
      ],
      "files": ["crates/storage/src/snapshot.rs", "crates/storage/src/lib.rs"],
      "depends_on": ["T4.2"]
    },
    "T4.4": {
      "name": "Implement snapshot restore",
      "description": "Implement restoring from checkpoint directory",
      "acceptance": [
        "Restores from checkpoint directory",
        "Data matches snapshot",
        "State machine functional after restore"
      ],
      "files": ["crates/storage/src/snapshot.rs", "crates/storage/src/lib.rs"],
      "depends_on": ["T4.3"]
    },

    "T5.1": {
      "name": "Implement RaftLogStorage trait",
      "description": "Implement openraft::RaftLogStorage for RocksDB using storage-v2 API",
      "acceptance": [
        "Implements RaftLogStorage trait",
        "All trait methods implemented",
        "Async methods use async-trait"
      ],
      "files": ["crates/storage/src/rocksdb_log.rs"],
      "depends_on": []
    },
    "T5.2": {
      "name": "Implement RaftStateMachine trait",
      "description": "Implement openraft::RaftStateMachine for RocksDB",
      "acceptance": [
        "Implements RaftStateMachine trait",
        "All trait methods implemented",
        "apply() uses idempotency check"
      ],
      "files": ["crates/storage/src/rocksdb_state_machine.rs"],
      "depends_on": ["T5.1"]
    },
    "T5.3": {
      "name": "Integration tests",
      "description": "Test single-node cluster with RocksDB storage, verify crash recovery",
      "acceptance": [
        "Single-node cluster starts with RocksDB",
        "SET/GET operations persist",
        "Crash recovery works",
        "No data loss after restart"
      ],
      "files": ["crates/storage/tests/rocksdb_tests.rs"],
      "depends_on": ["T5.2"]
    }
  }
}
