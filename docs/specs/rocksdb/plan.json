{
  "feature": "rocksdb-storage",
  "description": "Persistent storage layer with RocksDB for durability",
  "type": "storage_implementation",
  "estimated_effort_hours": "14-17",
  "total_phases": 5,
  "status": "not_started",
  "dependencies": ["openraft"],

  "phases": {
    "initialization": {
      "name": "RocksDB Initialization",
      "description": "Set up RocksDB with 6 column families",
      "order": 1,
      "dependencies": [],
      "estimated_hours": "3-4",
      "tasks": ["create_column_families", "configure_options", "test_open_close"],
      "files_affected": [
        "crates/storage/src/rocksdb.rs",
        "crates/storage/src/lib.rs"
      ],
      "success_criteria": [
        "6 column families created: system_raft_log, system_raft_state, system_data, data_raft_log, data_raft_state, data_kv",
        "RocksDB opens successfully",
        "RocksDB closes cleanly"
      ]
    },
    "basic_operations": {
      "name": "CRUD Operations",
      "description": "Implement basic get/put/delete operations per column family",
      "order": 2,
      "dependencies": ["initialization"],
      "estimated_hours": "3-4",
      "tasks": ["implement_get", "implement_put", "implement_delete", "implement_exists", "batch_writes"],
      "files_affected": [
        "crates/storage/src/rocksdb.rs"
      ],
      "success_criteria": [
        "get() returns correct value or None",
        "put() stores value and persists to disk",
        "delete() removes key",
        "exists() returns bool",
        "Batch write is atomic"
      ]
    },
    "raft_log_storage": {
      "name": "Raft Log Storage",
      "description": "Implement RaftLogStorage trait for log persistence",
      "order": 3,
      "dependencies": ["basic_operations"],
      "estimated_hours": "3-4",
      "tasks": ["implement_log_append", "implement_log_get_range", "implement_log_truncate", "implement_vote_storage"],
      "files_affected": [
        "crates/storage/src/rocksdb_log.rs"
      ],
      "success_criteria": [
        "append_entry() persists to data_raft_log",
        "get_log_entries() returns range",
        "truncate_log_after() removes entries after index",
        "vote storage works"
      ]
    },
    "state_machine_storage": {
      "name": "State Machine Storage",
      "description": "Implement RaftStateMachine trait for KV persistence",
      "order": 4,
      "dependencies": ["raft_log_storage"],
      "estimated_hours": "3-4",
      "tasks": ["implement_state_get", "implement_state_put", "implement_snapshot", "implement_snapshot_restore"],
      "files_affected": [
        "crates/storage/src/rocksdb_state_machine.rs"
      ],
      "success_criteria": [
        "State machine get returns correct value",
        "State machine put persists to data_kv",
        "Snapshot creation succeeds",
        "Snapshot restoration succeeds"
      ]
    },
    "openraft_integration": {
      "name": "OpenRaft Integration",
      "description": "Integrate RocksDB storage with OpenRaft storage traits",
      "order": 5,
      "dependencies": ["state_machine_storage"],
      "estimated_hours": "2-3",
      "tasks": ["implement_raft_log_storage_trait", "implement_raft_state_machine_trait", "integration_tests"],
      "files_affected": [
        "crates/storage/src/lib.rs"
      ],
      "success_criteria": [
        "OpenRaftRocksDBLog implements RaftLogStorage",
        "OpenRaftRocksDBStateMachine implements RaftStateMachine",
        "Single-node cluster test passes",
        "Crash recovery works"
      ]
    }
  },

  "tasks": {
